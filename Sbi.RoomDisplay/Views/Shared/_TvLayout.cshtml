@using Sbi.RoomDisplay.Helpers

@{
    Layout = null;

    var brandMode = BrandMode.Dark;

    var sbiLogo = BrandHelper.GetSbiLogo(brandMode);
    var sigLogo = BrandHelper.GetSigLogo(brandMode);

    var headerClass = brandMode == BrandMode.Light
        ? "header-light"
        : "header-dark";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SBI Room Display</title>
    <link rel="stylesheet" href="~/css/tv-display.css" />
</head>

<body class="tv-page">
    <div class="tv-wrapper">

        <header class="tv-header @headerClass">
            <div class="brand-left">
                <img src="@sbiLogo" alt="SBI logo" />
                <img src="@sigLogo" alt="SIG logo" />
            </div>

            <div class="room-title">
                @RenderSection("RoomTitle", false)
            </div>

            <div class="header-right">
                <div class="clock" id="clock">--:--:--</div>
                <div class="sync-status idle" id="syncStatusText">
                    AUTO REFRESH 10S
                </div>
            </div>
        </header>

        <main class="tv-main">
            @RenderBody()
        </main>

        <footer class="tv-footer">
            © PT Solusi Bangun Indonesia Tbk
        </footer>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>