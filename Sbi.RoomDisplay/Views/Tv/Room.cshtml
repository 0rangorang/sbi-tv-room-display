@model Sbi.RoomDisplay.Models.RoomScheduleViewModel

@{
    Layout = "~/Views/Shared/_TvLayout.cshtml";
}

@section RoomTitle {
    @Model.RoomName
}


<div class="tv-body">

    <div class="left-panel">
        <h2>Current Activity</h2>

        <div id="currentActivity">
            @if (Model.CurrentBooking != null)
            {
                <div class="info">@Model.CurrentBooking.DisplayTitle</div>
                <div class="info">PIC: @Model.CurrentBooking.PIC</div>
                <div class="info">
                    @Model.CurrentBooking.StartTime.ToString("HH:mm")
                    -
                    @Model.CurrentBooking.EndTime.ToString("HH:mm")
                </div>
            }
            else
            {
                <div class="info">Room Available</div>
            }
        </div>
    </div>

    <div class="right-panel">
        <h2>Today's Schedule</h2>

        <div id="timeline">
            @foreach (var slot in Model.Slots)
            {
                var cssClass = slot.Status.ToString().ToLower();

                <div class="slot-row @cssClass">
                    <div>@slot.Time.ToString("HH:mm")</div>
                    <div>@slot.Description</div>
                </div>
            }

            <div id="time-indicator"></div>

        </div>
    </div>

</div>

@section Scripts {
<script>

function updateTimeIndicator() {

    const slots = document.querySelectorAll(".slot-row");
    const indicator = document.getElementById("time-indicator");

    if (!slots.length || !indicator) return;

    const now = window.serverNow ?? new Date();

    const startHour = 6;
    const endHour = 20;

    const totalMinutes = (endHour - startHour) * 60;
    const currentMinutes =
        (now.getHours() - startHour) * 60 + now.getMinutes();

    const percent = Math.max(0, Math.min(1, currentMinutes / totalMinutes));

    // ✅ HITUNG BERDASARKAN SLOT NYATA
    const firstSlot = slots[0];
    const lastSlot = slots[slots.length - 1];

    const startY = firstSlot.offsetTop;
    const endY = lastSlot.offsetTop + lastSlot.offsetHeight;

    const position = startY + (endY - startY) * percent;

    indicator.style.top = position + "px";
}

// ✅ TUNGGU layout selesai dulu
window.addEventListener("load", () => {
    updateTimeIndicator();
    setInterval(() => {
        requestAnimationFrame(updateTimeIndicator);
    }, 1000);
});

function updateClock() {

    if (!window.serverNow) return;  

    const now = new Date(window.serverNow);

    const time =
        now.toLocaleTimeString([], {
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit'
        });

    document.getElementById("clock").innerText = time;

    // maju 1 detik lokal
    window.serverNow =
        new Date(now.getTime() + 1000);
}

async function startClock() {
    await syncServerTime();
    updateClock();
    setInterval(updateClock, 1000);
}
startClock();

async function syncServerTime() {
    const r = await fetch("/time");
    const d = await r.json();

    window.serverNow = new Date(d.now);
}

// sync pertama
syncServerTime();

// sync tiap 10 detik
setInterval(syncServerTime, 10000);

</script>
}

<script src="~/js/tv-refresh.js"></script>